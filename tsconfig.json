{
  "compilerOptions": {
    "target": "ES2022", // Node.js 20+ (Node 22 in Docker) supports ES2022 fully
    "module": "NodeNext", // Use Node.js ESM module resolution
    "outDir": "dist", // Output compiled files here
    "rootDir": ".", // Source files root (includes src/, generated/, types/)
    "moduleResolution": "NodeNext", // Match module system
    "esModuleInterop": true, // Enable interoperability between CommonJS and ES modules
    "forceConsistentCasingInFileNames": true, // Enforce consistent casing in imports
    "strict": true, // Enable all strict type-checking options
    "skipLibCheck": true, // Skip type checking of declaration files for faster builds
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ], // Include custom and npm types
    "paths": {
      // @actual-app/core ships TypeScript source files (not compiled .d.ts).
      // From @actual-app/api v26.4.0 it is imported directly, causing tsc to
      // compile those source files with our strict settings — and they require
      // typescript-strict-plugin to pass, which tsc doesn't support.
      // This stub redirects all @actual-app/core/* imports to a no-op declaration
      // so TypeScript never follows into its source. All type information we
      // actually use flows through @actual-app/api's own compiled declarations.
      "@actual-app/core": ["./types/actual-core-stub.d.ts"],
      "@actual-app/core/*": ["./types/actual-core-stub.d.ts"]
    }
  },
  "include": [
    "src/**/*",
    "types/**/*",
    "generated/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}