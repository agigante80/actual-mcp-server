{
  "compilerOptions": {
    "target": "ES2022", // Node.js 20+ (Node 22 in Docker) supports ES2022 fully
    "module": "NodeNext", // Use Node.js ESM module resolution
    "outDir": "dist", // Output compiled files here
    "rootDir": ".", // Source files root (includes src/, generated/, types/)
    "moduleResolution": "NodeNext", // Match module system
    "esModuleInterop": true, // Enable interoperability between CommonJS and ES modules
    "forceConsistentCasingInFileNames": true, // Enforce consistent casing in imports
    "strict": true, // Enable all strict type-checking options
    "skipLibCheck": true, // Skip type checking of declaration files for faster builds
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ] // Include custom and npm types
  },
  "include": [
    "src/**/*",
    "types/**/*",
    "generated/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}