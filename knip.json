{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.ts",
    "bin/actual-mcp-server.js",
    "src/tools/index.ts",
    "src/server/httpServer.ts",
    "src/server/stdioServer.ts",
    "src/tests_adapter_runner.ts",
    "src/tests/testMcpClient.ts",
    "src/prompts/showLargeTransactions.ts",
    "src/resources/accountsSummary.ts",
    "scripts/**/*.{js,mjs}",
    "tests/unit/**/*.test.js",
    "tests/e2e/**/*.spec.ts",
    "tests/e2e/suites/**/*.ts",
    "tests/manual/index.js",
    "tests/manual/tests/**/*.js",
    "tests/manual/*.mjs",
    "playwright.config.ts",
    "playwright.config.docker.ts"
  ],
  "project": ["src/**/*.ts"],
  "ignoreExportsUsedInFile": true
}
